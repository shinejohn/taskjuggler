{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "nixpacksConfigPath": "nixpacks.toml"
    },
    "deploy": {
        "startCommand": "php artisan queue:work redis --tries=3 --max-time=3600 --sleep=3",
        "numReplicas": 1,
        "restartPolicyType": "ALWAYS"
    }
}
