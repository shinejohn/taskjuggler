APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Command Center CRM provisioning bridge (shared secret for X-Provisioning-Secret header)
PROVISIONING_SECRET=

# Multisite publishing platform bridge (base URL includes /api/v1)
PUBLISHING_API_URL=
PUBLISHING_BRIDGE_API_KEY=

# MCP server
MCP_SERVER_URL=https://mcp.taskjuggler.com

# TaskJuggler sync (self-referencing API URL for cross-module sync)
TASKJUGGLER_API_URL=http://localhost:8000/api

# Matrix / Dendrite (Phase 2 comms — disabled until homeserver is deployed)
MATRIX_ENABLED=false
MATRIX_HOMESERVER_URL=
MATRIX_SERVER_NAME=fibonacco.ai
MATRIX_ADMIN_TOKEN=
MATRIX_REGISTRATION_SHARED_SECRET=
MATRIX_APPSERVICE_TOKEN=
MATRIX_WEBHOOK_SECRET=
MATRIX_ROOM_VISIBILITY=private

# LiveKit (Phase 3 — IdeaCircuit video + URPA voice rooms)
LIVEKIT_ENABLED=false
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL=3600

# Pipecat voice agent (Phase 4 — replaces Vapi when enabled)
PIPECAT_ENABLED=false
PIPECAT_AGENT_URL=http://localhost:8080
PIPECAT_WEBHOOK_SECRET=
PIPECAT_REPLACE_VAPI=false

# URPA channel connector (openclaw-connector sidecar)
URPA_CHANNEL_WEBHOOK_SECRET=
DEEPGRAM_API_KEY=

# App / API
API_VERSION=
FRONTEND_URL=http://localhost:5173
DATABASE_URL=
BROADCAST_DRIVER=log

# Module toggles
MODULE_TASKS_ENABLED=true
MODULE_PROCESSES_ENABLED=true
MODULE_PROJECTS_ENABLED=true

# AI providers
AI_TOOLS_PROVIDER=
AI_TOOLS_MODEL=
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_DEFAULT_MODEL=
OPENROUTER_EXTRACTION_MODEL=

# ElevenLabs (voice synthesis)
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=

# Vapi (voice AI)
VAPI_API_KEY=
VAPI_BASE_URL=
VAPI_WEBHOOK_SECRET=

# Twilio (voice/SMS)
