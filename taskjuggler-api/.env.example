MQTT_TIMEOUT=5
MQTT_TLS_ENABLED=false
MQTT_TLS_VERIFY_PEER=true
MQTT_TLS_CA_FILE=
MQTT_TLS_CERT_FILE=
MQTT_TLS_KEY_FILE=
MQTT_PUBLIC_HOST=
MQTT_PUBLIC_PORT=1883
MQTT_PUBLIC_CLIENT_ID=
